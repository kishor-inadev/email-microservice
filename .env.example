# Server Configuration
NODE_ENV=development
PORT=3500
LOG_LEVEL=info
ENABLE_LOGGING=true       # Set to 'false' to completely disable logging (fastest)
DISABLE_CONSOLE_LOG=false # Set to 'true' to disable console output (keep file logs only)
ENABLE_FILE_LOGS=false    # Set to 'true' to enable file logging (recommended for production)

# Cluster Mode (multi-core)
ENABLE_CLUSTER=true
CLUSTER_WORKERS=0  # 0 = auto-detect CPU cores

# Server Timeouts
REQUEST_TIMEOUT_MS=30000
SERVER_TIMEOUT_MS=120000
SHUTDOWN_TIMEOUT_MS=10000

# Trust Proxy (set true behind load balancer)
TRUST_PROXY=false

# CORS
CORS_ORIGIN=*

# App / Branding — used in email template links, CTA buttons, and footer.
# These can be overridden per-request via HTTP headers:
#   x-app       → applicationName
#   x-app-url   → appUrl (base domain for all CTA links)
#   x-path      → ctaPath (override the primary CTA page path)
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
APPLICATION_NAME=Your Company

# MongoDB (Optimized for High Throughput)
MONGO_URL=mongodb+srv://username:password@cluster.mongocluster.cosmos.azure.com/?tls=true&authMechanism=SCRAM-SHA-256&retrywrites=false&maxIdleTimeMS=120000
MONGO_MAX_POOL_SIZE=100          # Increased for high throughput (default: 20)
MONGO_MIN_POOL_SIZE=20           # Increased min pool (default: 2)
MONGO_WRITE_CONCERN=1
MONGO_READ_PREFERENCE=primaryPreferred

# Kafka Configuration (For Async Processing & Unlimited Ingestion)
ENABLE_KAFKA=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=kafka-core-service
KAFKA_GROUP_ID=email-service-consumer-group
KAFKA_TOPIC_SEND=email.notification.send
KAFKA_TOPIC_SUCCESS=email.notification.delivered
KAFKA_TOPIC_FAILED=email.notification.failed
KAFKA_CONCURRENT_PARTITIONS=10   # Increased for parallel processing (default: 3)

# Email Configuration
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
DEFAULT_FROM_NAME=Your App Name

EMAIL_SERVICE=
EMAIL_HOST=smtp-relay.brevo.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-smtp-user@brevo.com
EMAIL_PASS=your-brevo-smtp-password

# OAuth2 Credentials (Optional)
OAUTH2_CLIENT_ID=your-client-id.apps.googleusercontent.com
OAUTH2_CLIENT_SECRET=your-client-secret
OAUTH2_REFRESH_TOKEN=your-refresh-token
OAUTH2_REDIRECT_URI=https://developers.google.com/oauthplayground

# Fallback Email Service Configuration
FALLBACK_EMAIL_SERVICE=gmail
FALLBACK_EMAIL_HOST=smtp.gmail.com
FALLBACK_EMAIL_PORT=587
FALLBACK_EMAIL_SECURE=false
FALLBACK_EMAIL_USER=fallback-email@example.com
FALLBACK_EMAIL_PASS=fallback-app-password

# Advanced Email Settings (Optimized for High Throughput)
# Email throughput: Adjust based on your SMTP provider limits
# - Gmail: 20-100 connections, 500 emails/sec max
# - SendGrid/AWS SES: 100-200 connections, 1000+ emails/sec
# - Brevo: 50-100 connections, 300 emails/sec
EMAIL_MAX_CONNECTIONS=100        # Concurrent SMTP connections (default: 20)
EMAIL_MAX_MESSAGES=500           # Messages per connection before cycling (default: 500)
EMAIL_RATE_LIMIT=500             # Max emails per rate window (default: 50)
EMAIL_RATE_DELTA=1000            # Rate window in ms (1000 = 1 second) (default: 1000)
EMAIL_TLS_REJECT_UNAUTHORIZED=true
EMAIL_TLS_MIN_VERSION=TLSv1.2
EMAIL_DEBUG=false

# Email Service Configuration
EMAIL_RETRY_LIMIT=3
EMAIL_RETRY_BACKOFF_MS=5000
ENABLE_SYNC_ENDPOINT=true

# Idempotency Configuration
IDEMPOTENCY_TTL_MS=3600000
IDEMPOTENCY_CLEANUP_INTERVAL_MS=300000

# Security - HTTP Rate Limiting (per IP address)
# Production recommended: 1000 requests per minute per IP
RATE_LIMIT_WINDOW_MS=60000       # 1 minute window (default: 15 minutes)
RATE_LIMIT_MAX_REQUESTS=1000     # Max requests per window per IP (default: 100)

# Redis (for production idempotency - uncomment when needed)
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=
# Tenant configuration
# true  → resolve tenant from x-tenant-id header (fallback: DEFAULT_TENANT_ID).
# false → do not resolve/check tenant; ignore x-tenant-id even if provided.
TENANCY_ENABLED=false
# Fallback tenant when x-tenant-id header is absent. Leave blank (null) to require the header explicitly.
DEFAULT_TENANT_ID=
